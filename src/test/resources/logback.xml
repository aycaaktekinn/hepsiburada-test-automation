<?xml version="1.0" encoding="UTF-8"?>

<configuration>

    <!-- Konsola log yazdırır. -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss} [%level] %logger{30} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- Logları target/logs/test-automation.log dosyasına kaydeder. -->
    <appender name="FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>target/logs/test-automation.log</file>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

            <fileNamePattern>
                target/logs/test-automation-%d{yyyy-MM-dd}.log
            </fileNamePattern>

            <maxHistory>7</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss} [%level] %logger{30} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- INFO ve üzerindeki loglar yazdırılır. -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>